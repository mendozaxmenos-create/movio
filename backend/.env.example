# Postgres en la nube (Neon, Vercel Postgres, Supabase, etc.)
DATABASE_URL=postgresql://user:pass@host.region.provider.com/db?sslmode=require

# Si no definís DATABASE_URL, el backend usa archivo local data/movio-data.json

PORT=4000

# Poné SKIP_SEED=1 en producción si no querés datos de demo al arrancar vacío
# SKIP_SEED=1
